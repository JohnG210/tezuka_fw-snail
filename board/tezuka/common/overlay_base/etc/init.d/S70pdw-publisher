#!/bin/sh
# S70pdw-publisher — Start ZMQ PDW publisher daemon (EW mode only)
#
# Disabled in standby/sigint modes by S01mode.
# Starts after maia-kmod (S50) loads UIO devices.
#
# Default: PDW topic only (-t pdw). For PDW+IQ, restart with -t all:
#   /etc/init.d/S70pdw-publisher stop
#   screen -S pdw -dm /usr/bin/pdw-publisher -t all -v
#
# Attach to see live logs:  screen -r pdw

DAEMON=/usr/bin/pdw-publisher
SCREEN_NAME=pdw
export SCREENDIR=/tmp/screen
export HOME=/root

case "$1" in
start)
    [ -x "$DAEMON" ] || exit 0
    # Only start if UIO1 device node exists (EW engine in DTB)
    if [ ! -e /dev/uio1 ]; then
        echo "pdw-publisher: no /dev/uio1, skipping"
        exit 0
    fi
    mkdir -p "$SCREENDIR"
    chmod 700 "$SCREENDIR"
    echo -n "Starting pdw-publisher (screen '$SCREEN_NAME'): "
    screen -S $SCREEN_NAME -dm $DAEMON -t pdw -v
    [ $? = 0 ] && echo "OK" || echo "FAIL"
    ;;
stop)
    echo -n "Stopping pdw-publisher: "
    screen -S $SCREEN_NAME -X quit 2>/dev/null
    killall pdw-publisher 2>/dev/null
    [ $? = 0 ] && echo "OK" || echo "FAIL"
    ;;
restart|reload)
    $0 stop
    sleep 1
    $0 start
    ;;
*)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
